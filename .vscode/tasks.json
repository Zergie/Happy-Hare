    "version": "2.0.0",
    "tasks": [
        {
            "label": "Sync Klipper/Kalico extras links",
            "icon": {
                "id": "sync",
                "color": "terminal.ansiCyan"
            },
            "type": "shell",
            "command": [
                "pwsh -NoProfile -ExecutionPolicy Bypass -Command {",
                "$sourceExtras = 'C:/git/YAMMU/Firmware/Happy-Hare/extras';",
                "$sourceMmu = Join-Path $sourceExtras 'mmu';",
                "$targetExtrasDirs = @('C:/git/klipper/klippy/extras', 'C:/git/kalico/klippy/extras');",
                "if (-not (Test-Path $sourceExtras)) { throw \"Missing source extras dir: $sourceExtras\" };",
                "if (-not (Test-Path $sourceMmu)) { throw \"Missing source mmu dir: $sourceMmu\" };",
                "$managedSourceFiles = @(Get-ChildItem -Path $sourceExtras -File -Filter '*.py' | Select-Object -ExpandProperty FullName);",
                "$sourcePylintRc = Join-Path $sourceExtras '.pylintrc';",
                "if (Test-Path $sourcePylintRc) { $managedSourceFiles += $sourcePylintRc };",
                "foreach ($targetExtras in $targetExtrasDirs) {",
                "  if (-not (Test-Path $targetExtras)) { throw \"Missing target extras dir: $targetExtras\" };",
                "  $existingManaged = @();",
                "  $existingManaged += Get-ChildItem -Path $targetExtras -File -Filter '*.py' -ErrorAction SilentlyContinue;",
                "  if (Test-Path (Join-Path $targetExtras '.pylintrc')) { $existingManaged += Get-Item -Path (Join-Path $targetExtras '.pylintrc') -Force };",
                "  foreach ($item in $existingManaged) {",
                "    if (($item.Attributes -band [IO.FileAttributes]::ReparsePoint) -eq 0) { continue };",
                "    $targetValue = (Get-Item -Path $item.FullName -Force).Target;",
                "    if ($targetValue -is [array]) { $targetValue = $targetValue[0] };",
                "    if (-not $targetValue) { continue };",
                "    $sourceCandidate = Join-Path $sourceExtras $item.Name;",
                "    if ($targetValue -like 'C:/git/YAMMU/Firmware/Happy-Hare/extras/*' -and -not (Test-Path $sourceCandidate)) {",
                "      Remove-Item -Path $item.FullName -Force;",
                "      Write-Host \"Removed stale link: $($item.FullName)\";",
                "    }",
                "  }",
                "  foreach ($src in $managedSourceFiles) {",
                "    $dest = Join-Path $targetExtras (Split-Path $src -Leaf);",
                "    if (Test-Path $dest) { Remove-Item -Path $dest -Recurse -Force };",
                "    New-Item -ItemType SymbolicLink -Path $dest -Target $src | Out-Null;",
                "    Write-Host \"Linked file: $dest -> $src\";",
                "  }",
                "  $destMmu = Join-Path $targetExtras 'mmu';",
                "  if (Test-Path $destMmu) { Remove-Item -Path $destMmu -Recurse -Force };",
                "  New-Item -ItemType Junction -Path $destMmu -Target $sourceMmu | Out-Null;",
                "  Write-Host \"Linked folder: $destMmu -> $sourceMmu\";",
                "}",
                "Write-Host 'Sync complete: klipper and kalico extras linked to Happy-Hare extras.';",
                "}"
            ],
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
