    "version": "2.0.0",
    "tasks": [
        {
            "label": "Export Code to Test Rig",
            "type": "shell",
            "command": [
                "pwsh -NoProfile -ExecutionPolicy Bypass -Command {",
                ". C:/GIT/YAMMU/Firmware/Sync-TestRig.ps1 -Export;",
                "}"
            ],
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Export Startup.gcode to Test Rig",
            "type": "shell",
            "command": [
                "pwsh -NoProfile -ExecutionPolicy Bypass -Command {",
                "scp C:/GIT/YAMMU/Firmware/Happy-Hare/.github/skills/run-test-rig/startup.gcode klippy-test:/tmp/startup.gcode;",
                "}"
            ],
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Start on Test Rig",
            "type": "shell",
            "command": [
                "pwsh -NoProfile -ExecutionPolicy Bypass -Command {",
                ". C:/GIT/YAMMU/Firmware/Sync-TestRig.ps1 -Export;",
                "ssh klippy-test rm /home/user/printer_data/logs/klippy.log;",
                "ssh klippy-test /home/user/klippy-env/bin/python /home/user/klipper/klippy/klippy.py /home/user/printer_data/config/printer.cfg -I /home/user/printer_data/comms/klippy.serial -l /home/user/printer_data/logs/klippy.log -a /home/user/printer_data/comms/klippy.sock;",
                "}"
            ],
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "label": "Stop on Test Rig",
            "type": "shell",
            "command": "ssh",
            "args": [
                "klippy-test",
                "pgrep -f klippy-env/bin/python && kill `pgrep -f klippy-env/bin/python`"
            ],
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "label": "Run Startup.gcode on Test Rig",
            "type": "shell",
            "command": [
                "pwsh -NoProfile -ExecutionPolicy Bypass -Command {",
                "ssh klippy-test rm /home/user/printer_data/logs/klippy.log;",
                "scp C:/GIT/YAMMU/Firmware/Happy-Hare/.github/skills/run-test-rig/startup.gcode klippy-test:/tmp/startup.gcode;",
                ". C:/GIT/YAMMU/Firmware/Sync-TestRig.ps1 -Export;",
                "ssh klippy-test /home/user/klippy-env/bin/python /home/user/klipper/klippy/klippy.py /home/user/printer_data/config/printer.cfg -i /tmp/startup.gcode -l /home/user/printer_data/logs/klippy.log -a /home/user/printer_data/comms/klippy.sock;",
                "scp klippy-test:/home/user/printer_data/logs/klippy.log \"C:\\git\\YAMMU\\Firmware\\Happy-Hare\\.github\\skills\\run-test-rig\\klippy.log\";",
                "}"
            ],
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "label": "FIRMWARE_RESTART on Test Rig",
            "type": "shell",
            "command": [
                "pwsh -NoProfile -ExecutionPolicy Bypass -Command {",
                "ssh klippy-test rm /home/user/printer_data/logs/klippy.log;",
                "ssh klippy-test 'echo FIRMWARE_RESTART > /tmp/restart.gcode';",
                "ssh klippy-test /home/user/klippy-env/bin/python /home/user/klipper/klippy/klippy.py /home/user/printer_data/config/printer.cfg -i /tmp/restart.gcode -l /home/user/printer_data/logs/klippy.log -a /home/user/printer_data/comms/klippy.sock;",
                "scp klippy-test:/home/user/printer_data/logs/klippy.log \"C:\\git\\YAMMU\\Firmware\\Happy-Hare\\.github\\skills\\run-test-rig\\klippy.log\";",
                "}"
            ],
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "label": "Get klippy.log from Test Rig",
            "type": "shell",
            "command": [
                "pwsh -NoProfile -ExecutionPolicy Bypass -Command {",
                "scp klippy-test:/home/user/printer_data/logs/klippy.log \"C:\\git\\YAMMU\\Firmware\\Happy-Hare\\.github\\skills\\run-test-rig\\klippy.log\";",
                "}"
            ],
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "label": "Plot PWM Graph",
            "type": "process",
            "command": "c:/GIT/YAMMU/Firmware/Happy-Hare/.venv/Scripts/python.exe",
            "args": [
                "C:/git/YAMMU/Firmware/Happy-Hare/utils/plot_bldc_pwm.py",
                "--input",
                "C:/git/YAMMU/Firmware/Happy-Hare/.github/skills/run-test-rig/klippy.log",
            ],
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
    ]
}